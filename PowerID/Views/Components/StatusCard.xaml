<UserControl
    x:Class="PowerID.Views.Components.StatusCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border CornerRadius="12"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="Gray"
            BorderThickness="1"
            Padding="16">
        <StackPanel Orientation="Horizontal" Spacing="16">
            <Border x:Name="IconBackground" Width="50" Height="50" CornerRadius="12">
                <TextBlock x:Name="IconGlyph" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock x:Name="TitleText" Opacity="0.7" FontSize="13" />
                <TextBlock x:Name="ValueText" FontSize="18" FontWeight="SemiBold" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
