<Window
    x:Class="PowerID.Views.Settings.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:settings="using:PowerID.Views.Settings">

    <Grid>
        <Pivot x:Name="SettingsPivot">
            <PivotItem Header="General">
                <settings:GeneralSettingsView x:Name="GeneralView" />
            </PivotItem>
            <PivotItem Header="Notifications">
                <settings:NotificationsSettingsView x:Name="NotificationsView" />
            </PivotItem>
            <PivotItem Header="About">
                <settings:AboutSettingsView />
            </PivotItem>
        </Pivot>
    </Grid>
</Window>
